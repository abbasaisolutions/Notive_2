# Environment variables declared in this file are automatically made available to Prisma.
# See the documentation for more detail: https://pris.ly/d/prisma-schema#accessing-environment-variables-from-the-schema

# PostgreSQL connection string
DATABASE_URL="postgresql://user:password@localhost:5432/notive_db?schema=public"

# JWT Secrets (generate strong random strings for production!)
JWT_ACCESS_SECRET="notive_access_secret_change_in_production"
JWT_REFRESH_SECRET="notive_refresh_secret_change_in_production"

# Token Expiry
ACCESS_TOKEN_EXPIRY="15m"
REFRESH_TOKEN_EXPIRY="7d"

# Server Port
PORT=8000
CORS_ORIGINS="http://localhost:3000"
CLIENT_URL="http://localhost:3000"
API_URL="http://localhost:8000/api/v1"

# Meta Social OAuth (required for real social connection/import)
# No mock/dummy fallback is used.
META_GRAPH_API_VERSION="v22.0"
FACEBOOK_APP_ID=""
FACEBOOK_APP_SECRET=""
FACEBOOK_REDIRECT_URI="http://localhost:8000/api/v1/import/callback/facebook"

# Instagram import uses Meta Graph API.
# You can reuse the same Meta app credentials as Facebook, or set dedicated values.
INSTAGRAM_APP_ID=""
INSTAGRAM_APP_SECRET=""
INSTAGRAM_REDIRECT_URI="http://localhost:8000/api/v1/import/callback/instagram"
OAUTH_STATE_SECRET="replace_with_long_random_state_secret"
OAUTH_STATE_TTL_MS="600000"
SOCIAL_TOKEN_ENCRYPTION_KEY="replace_with_long_random_encryption_secret"

# Deterministic NLP microservice
NLP_SERVICE_URL="http://localhost:8001"
# Optional: enable transformer-backed models inside the Python NLP microservice
NLP_ENABLE_ADVANCED_MODELS="false"
SPACY_MODEL="en_core_web_sm"
NLP_SENTIMENT_MODEL="cardiffnlp/twitter-roberta-base-sentiment-latest"
NLP_EMOTION_MODEL="j-hartmann/emotion-english-distilroberta-base"
NLP_ZERO_SHOT_MODEL="facebook/bart-large-mnli"
NLP_EVIDENCE_MIN_SCORE="0.45"
NLP_EVIDENCE_MAX_SENTENCES="12"

# Optional: enable LLM analysis/tagging (costly)
USE_LLM_NLP="false"
USE_LLM_TAGGING="false"
OPPORTUNITY_EVIDENCE_MODEL="gpt-4o-mini"
LLM_NLP_CONFIDENCE_THRESHOLD="0.28"
LLM_NLP_MIN_WORDS="80"
LLM_TAGGING_MIN_LOCAL_TAGS="3"

# Optional: semantic embedding generation
# - local_hash: no external model/API dependency
# - local_service: local similarity-service embeddings
# - openai: external API embeddings
USE_EMBEDDINGS="true"
EMBEDDING_PROVIDER="local_service"
EMBEDDING_SERVICE_URL="http://localhost:8002"
SIMILARITY_SERVICE_URL="http://localhost:8002"
EMBEDDING_MODEL="BAAI/bge-small-en-v1.5"
EMBEDDING_DIMS="1536"
SEARCH_LEXICAL_TAIL_MIN_RELEVANCE="0.05"

# Optional: generative provider for chat/rewrite only.
# Leave disabled to use Guided Reflection mode instead.
LLM_PROVIDER="disabled"
LLM_API_KEY=""
LLM_CHAT_MODEL="gpt-4o-mini"
