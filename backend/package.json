{
    "name": "notive-backend",
    "version": "0.1.0",
    "private": true,
    "license": "UNLICENSED",
    "scripts": {
        "start": "node dist/index.js",
        "migrate:deploy": "prisma migrate deploy",
        "predev": "prisma generate",
        "dev": "nodemon --exec \"ts-node --files\" src/index.ts",
        "build": "prisma generate && tsc",
        "typecheck": "tsc --noEmit",
        "test": "vitest run",
        "test:watch": "vitest",
        "seed:admin": "node scripts/seed-admin.js",
        "user:create-superadmin": "ts-node scripts/create-superadmin.ts",
        "audit:runtime": "npm audit --omit=dev --omit=peer --omit=optional --audit-level=high",
        "audit:full": "npm audit",
        "backfill:tags": "ts-node scripts/backfill-tags.ts",
        "backfill:embeddings": "ts-node scripts/backfill-embeddings.ts",
        "backfill:embeddings:force": "ts-node scripts/backfill-embeddings.ts --force",
        "retrieval:doctor": "ts-node scripts/retrieval-rollout-check.ts",
        "retrieval:build-eval": "ts-node scripts/build-private-retrieval-eval.ts",
        "retrieval:evaluate-pipeline": "ts-node scripts/evaluate-retrieval-pipeline.ts",
        "backfill:opportunity": "ts-node scripts/backfill-opportunity-evidence.ts"
    },
    "dependencies": {
        "@prisma/adapter-pg": "^7.4.1",
        "@prisma/client": "^7.4.1",
        "@sentry/node": "^10.47.0",
        "axios": "^1.13.2",
        "bcryptjs": "^3.0.3",
        "cookie-parser": "^1.4.7",
        "cors": "^2.8.5",
        "dotenv": "^16.4.1",
        "express": "^4.18.2",
        "firebase-admin": "^13.7.0",
        "google-auth-library": "^10.5.0",
        "jsonwebtoken": "^9.0.3",
        "mongoose": "^8.1.1",
        "multer": "^2.0.2",
        "openai": "^6.10.0",
        "pg": "^8.11.3",
        "redis": "^4.6.12",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@emnapi/core": "^1.9.2",
        "@emnapi/runtime": "^1.9.2",
        "@types/bcryptjs": "^2.4.6",
        "@types/cookie-parser": "^1.4.10",
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/multer": "^2.0.0",
        "@types/node": "^20.11.16",
        "@types/pg": "^8.11.0",
        "@types/supertest": "^7.2.0",
        "nodemon": "^3.0.3",
        "prisma": "^7.4.1",
        "supertest": "^7.2.2",
        "ts-node": "^10.9.2",
        "typescript": "^5.3.3",
        "vitest": "^4.1.2"
    },
    "overrides": {
        "gaxios": {
            "rimraf": "^6.0.1"
        }
    }
}
