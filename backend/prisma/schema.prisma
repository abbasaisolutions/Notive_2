// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
  SUPERADMIN
}

enum Category {
  PERSONAL
  PROFESSIONAL
}

enum TagSource {
  USER
  AI
  NLP
  IMPORT
  SYSTEM
}

enum AnalysisSource {
  DETERMINISTIC
  NLP
  AI
  IMPORT
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  password      String?  // Optional for SSO users
  name          String?
  avatarUrl     String?
  role          Role     @default(USER)
  isBanned      Boolean  @default(false)
  googleId      String?  @unique
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  // Password Reset
  resetToken       String?
  resetTokenExpiry DateTime?

  // Refresh tokens for this user
  refreshTokens RefreshToken[]
  
  // Profile
  profile       UserProfile?
  
  // Journal entries
  entries       Entry[]

  // Tag/analysis relations
  entryTags     EntryTag[]
  entryAnalyses EntryAnalysis[]
  entryEmbeddings EntryEmbedding[]
  personalizationEvents PersonalizationEvent[]
  
  // Chapters
  chapters      Chapter[]
  
  // Social Connections
  socialConnections SocialConnection[]
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Entry {
  id          String   @id @default(cuid())
  title       String?
  content     String   @db.Text
  contentHtml String?  @db.Text
  coverImage  String?
  audioUrl    String?
  mood        String?
  tags        String[]
  analysis    Json?
  contentVector Unsupported("tsvector")? @map("content_vector")
  category    Category @default(PERSONAL)
  lifeArea    String?  @db.VarChar(64)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  chapterId   String?
  chapter     Chapter? @relation(fields: [chapterId], references: [id], onDelete: SetNull)
  shareLinks  ShareLink[]
  entryTags   EntryTag[]
  analysisRecord EntryAnalysis?
  entryEmbeddings EntryEmbedding[]
  
  // Phase 2: Insights & Sharing
  lessons     String[]
  skills      String[]
  reflection  String?  @db.Text
  isShared    Boolean  @default(false)
  sharedToken String?  @unique
  
  // Phase 3: Social & Extensions
  source      EntrySource @default(NOTIVE)
  externalId  String?     
  sourceLink  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  @@index([userId, deletedAt, createdAt])
  @@index([userId, source, externalId])
  @@index([userId, chapterId, createdAt])
  @@index([userId, mood, createdAt])
  @@index([userId, lifeArea, createdAt])
}

model Tag {
  id         String     @id @default(cuid())
  name       String
  normalized String     @unique
  entryTags  EntryTag[]
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@index([normalized])
}

model EntryTag {
  id         String    @id @default(cuid())
  entryId    String
  tagId      String
  userId     String
  source     TagSource @default(USER)
  confidence Float     @default(1.0)
  createdAt  DateTime  @default(now())

  entry Entry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  tag   Tag   @relation(fields: [tagId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([entryId, tagId])
  @@index([userId, createdAt])
  @@index([tagId])
}

model EntryAnalysis {
  id             String         @id @default(cuid())
  entryId        String         @unique
  userId         String
  source         AnalysisSource @default(NLP)
  contentHash    String?
  summary        String?        @db.Text
  sentimentScore Float?
  sentimentLabel String?
  emotions       Json?
  entities       Json?
  topics         String[]
  keywords       String[]
  suggestedMood  String?
  wordCount      Int?
  readingTime    Int?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  entry Entry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, updatedAt])
}

model EntryEmbedding {
  id         String   @id @default(cuid())
  entryId    String
  userId     String
  model      String   @default("text-embedding-3-small")
  dimensions Int      @default(1536)
  contentHash String
  embedding  Unsupported("vector(1536)")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  entry Entry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([entryId, model, dimensions])
  @@index([userId, updatedAt])
  @@index([userId, model, dimensions])
}

enum EntrySource {
  NOTIVE
  FACEBOOK
  INSTAGRAM
}

model UserProfile {
  id          String    @id @default(cuid())
  userId      String    @unique
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio         String?   @db.Text
  location    String?
  occupation  String?
  website     String?
  birthDate   DateTime?
  lifeGoals   String[]
  primaryGoal String?
  focusArea   String?
  experienceLevel String?
  writingPreference String?
  starterPrompt String? @db.Text
  outputGoals String[] @default([])
  importPreference String?
  personalizationSignals Json?
  onboardingCompletedAt DateTime?
  personalizationEvents PersonalizationEvent[]
  updatedAt   DateTime  @updatedAt
}

model PersonalizationEvent {
  id         String   @id @default(cuid())
  userId     String
  profileId  String?
  eventType  String
  questionId String?
  field      String?
  value      String?  @db.Text
  pathname   String?
  metadata   Json?
  occurredAt DateTime
  fingerprint String  @db.VarChar(64)
  createdAt  DateTime @default(now())

  user    User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  profile UserProfile? @relation(fields: [profileId], references: [id], onDelete: SetNull)

  @@unique([userId, fingerprint])
  @@index([userId, occurredAt])
  @@index([userId, eventType, occurredAt])
}

model Chapter {
  id          String   @id @default(cuid())
  name        String
  description String?
  color       String   @default("#6366f1") // Primary purple
  icon        String?  @default("📖")
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  entries     Entry[]
  shareLinks  ShareLink[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ShareLink {
  id        String    @id @default(cuid())
  token     String    @unique @default(cuid())
  entryId   String?
  entry     Entry?    @relation(fields: [entryId], references: [id], onDelete: Cascade)
  chapterId String?
  chapter   Chapter?  @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  expiresAt DateTime?
  createdAt DateTime  @default(now())
}

model SocialConnection {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider     String   // 'INSTAGRAM', 'FACEBOOK'
  providerId   String?  // Social ID
  accessToken  String   @db.Text
  refreshToken String?  @db.Text
  expiresAt    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  @@unique([userId, provider])
}
