// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
  SUPERADMIN
}

enum Category {
  PERSONAL
  PROFESSIONAL
}

enum TagSource {
  USER
  AI
  NLP
  IMPORT
  SYSTEM
}

enum AnalysisSource {
  DETERMINISTIC
  NLP
  AI
  IMPORT
}

enum EmbeddingJobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum AccountDeletionRequestStatus {
  PENDING
  FULFILLED
  DISMISSED
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  password      String?  // Optional for SSO users
  name          String?
  avatarUrl     String?
  role          Role     @default(USER)
  isBanned      Boolean  @default(false)
  googleId      String?  @unique
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  // Password Reset
  resetToken       String?
  resetTokenExpiry DateTime?

  // Refresh tokens for this user
  refreshTokens RefreshToken[]
  
  // Profile
  profile       UserProfile?
  
  // Journal entries
  entries       Entry[]

  // Tag/analysis relations
  entryTags     EntryTag[]
  entryAnalyses EntryAnalysis[]
  entryEmbeddings EntryEmbedding[]
  entryEmbeddingChunks EntryEmbeddingChunk[]
  entryEmbeddingFacets EntryEmbeddingFacet[]
  embeddingJobs EmbeddingJob[]
  personalizationEvents PersonalizationEvent[]
  accountDeletionRequests AccountDeletionRequest[]
  
  // Chapters
  chapters      Chapter[]
  
  // Social Connections
  socialConnections SocialConnection[]
  
  // Google Fit Integration
  googleFitConnection GoogleFitConnection?
  healthContexts      HealthContext[]
  healthInsights      HealthInsight[]
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Entry {
  id          String   @id @default(cuid())
  title       String?
  content     String   @db.Text
  contentHtml String?  @db.Text
  coverImage  String?
  audioUrl    String?
  mood        String?
  tags        String[]
  analysis    Json?
  contentVector Unsupported("tsvector")? @map("content_vector")
  category    Category @default(PERSONAL)
  lifeArea    String?  @db.VarChar(64)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  chapterId   String?
  chapter     Chapter? @relation(fields: [chapterId], references: [id], onDelete: SetNull)
  shareLinks  ShareLink[]
  entryTags   EntryTag[]
  analysisRecord EntryAnalysis?
  entryEmbeddings EntryEmbedding[]
  entryEmbeddingChunks EntryEmbeddingChunk[]
  entryEmbeddingFacets EntryEmbeddingFacet[]
  embeddingJobs EmbeddingJob[]
  
  // Phase 2: Insights & Sharing
  lessons     String[]
  skills      String[]
  reflection  String?  @db.Text
  isShared    Boolean  @default(false)
  sharedToken String?  @unique
  
  // Phase 3: Social & Extensions
  source      EntrySource @default(NOTIVE)
  externalId  String?     
  sourceLink  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  @@index([userId, deletedAt, createdAt])
  @@index([userId, source, externalId])
  @@index([userId, chapterId, createdAt])
  @@index([userId, mood, createdAt])
  @@index([userId, lifeArea, createdAt])
}

model Tag {
  id         String     @id @default(cuid())
  name       String
  normalized String     @unique
  entryTags  EntryTag[]
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@index([normalized])
}

model EntryTag {
  id         String    @id @default(cuid())
  entryId    String
  tagId      String
  userId     String
  source     TagSource @default(USER)
  confidence Float     @default(1.0)
  createdAt  DateTime  @default(now())

  entry Entry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  tag   Tag   @relation(fields: [tagId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([entryId, tagId])
  @@index([userId, createdAt])
  @@index([tagId])
}

model EntryAnalysis {
  id             String         @id @default(cuid())
  entryId        String         @unique
  userId         String
  source         AnalysisSource @default(NLP)
  contentHash    String?
  summary        String?        @db.Text
  sentimentScore Float?
  sentimentLabel String?
  emotions       Json?
  entities       Json?
  topics         String[]
  keywords       String[]
  suggestedMood  String?
  wordCount      Int?
  readingTime    Int?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  entry Entry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, updatedAt])
}

model EntryEmbedding {
  id         String   @id @default(cuid())
  entryId    String
  userId     String
  model      String   @default("text-embedding-3-small")
  dimensions Int
  contentHash String
  embedding  Unsupported("vector")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  entry Entry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([entryId, model, dimensions])
  @@index([userId, updatedAt])
  @@index([userId, model, dimensions])
}

model EntryEmbeddingChunk {
  id          String   @id @default(cuid())
  entryId     String
  userId      String
  model       String   @default("text-embedding-3-small")
  dimensions  Int
  contentHash String
  chunkIndex  Int
  chunkCount  Int
  chunkText   String   @db.Text
  embedding   Unsupported("vector")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  entry Entry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([entryId, chunkIndex, model, dimensions])
  @@index([entryId, model, dimensions])
  @@index([userId, model, dimensions])
  @@index([userId, updatedAt])
}

model EntryEmbeddingFacet {
  id          String   @id @default(cuid())
  entryId      String
  userId       String
  model        String   @default("text-embedding-3-small")
  dimensions   Int
  contentHash  String
  facetType    String   @db.VarChar(64)
  facetKey     String   @db.VarChar(128)
  facetText    String   @db.Text
  embedding    Unsupported("vector")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  entry Entry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([entryId, facetType, facetKey, model, dimensions])
  @@index([entryId, model, dimensions])
  @@index([userId, model, dimensions])
  @@index([userId, facetType, model, dimensions])
  @@index([userId, updatedAt])
}

model EmbeddingJob {
  id           String             @id @default(cuid())
  entryId       String
  userId        String
  model         String             @default("text-embedding-3-small")
  dimensions    Int
  payload       Json
  status        EmbeddingJobStatus @default(PENDING)
  attemptCount  Int                @default(0)
  maxAttempts   Int                @default(4)
  runAfter      DateTime           @default(now())
  lockedAt      DateTime?
  lockedBy      String?            @db.VarChar(128)
  lastError     String?            @db.Text
  completedAt   DateTime?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  entry Entry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([entryId, model, dimensions])
  @@index([status, runAfter, createdAt])
  @@index([userId, status, runAfter])
  @@index([entryId, status])
}

enum EntrySource {
  NOTIVE
  FACEBOOK
  INSTAGRAM
}

model UserProfile {
  id          String    @id @default(cuid())
  userId      String    @unique
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio         String?   @db.Text
  location    String?
  occupation  String?
  website     String?
  birthDate   DateTime?
  lifeGoals   String[]
  primaryGoal String?
  focusArea   String?
  experienceLevel String?
  writingPreference String?
  starterPrompt String? @db.Text
  outputGoals String[] @default([])
  importPreference String?
  personalizationSignals Json?
  onboardingCompletedAt DateTime?
  personalizationEvents PersonalizationEvent[]
  updatedAt   DateTime  @updatedAt
}

model PersonalizationEvent {
  id         String   @id @default(cuid())
  userId     String
  profileId  String?
  eventType  String
  questionId String?
  field      String?
  value      String?  @db.Text
  pathname   String?
  metadata   Json?
  occurredAt DateTime
  fingerprint String  @db.VarChar(64)
  createdAt  DateTime @default(now())

  user    User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  profile UserProfile? @relation(fields: [profileId], references: [id], onDelete: SetNull)

  @@unique([userId, fingerprint])
  @@index([userId, occurredAt])
  @@index([userId, eventType, occurredAt])
}

model AccountDeletionRequest {
  id              String                       @id @default(cuid())
  email           String
  normalizedEmail String                       @db.VarChar(320)
  reason          String?                      @db.Text
  status          AccountDeletionRequestStatus @default(PENDING)
  requestedVia    String                       @default("WEB")
  matchedUserId   String?
  processedAt     DateTime?
  createdAt       DateTime                     @default(now())
  updatedAt       DateTime                     @updatedAt

  matchedUser User? @relation(fields: [matchedUserId], references: [id], onDelete: SetNull)

  @@index([normalizedEmail, createdAt])
  @@index([status, createdAt])
  @@index([matchedUserId, createdAt])
}

model Chapter {
  id          String   @id @default(cuid())
  name        String
  description String?
  color       String   @default("#6366f1") // Primary purple
  icon        String?  @default("📖")
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  entries     Entry[]
  shareLinks  ShareLink[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ShareLink {
  id        String    @id @default(cuid())
  token     String    @unique @default(cuid())
  entryId   String?
  entry     Entry?    @relation(fields: [entryId], references: [id], onDelete: Cascade)
  chapterId String?
  chapter   Chapter?  @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  expiresAt DateTime?
  createdAt DateTime  @default(now())
}

model SocialConnection {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider     String   // 'INSTAGRAM', 'FACEBOOK'
  providerId   String?  // Social ID
  accessToken  String   @db.Text
  refreshToken String?  @db.Text
  expiresAt    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  @@unique([userId, provider])
}

// Google Fit Connection - Separate from main Google Auth
model GoogleFitConnection {
  id           String    @id @default(cuid())
  userId       String    @unique
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken  String    @db.Text
  refreshToken String    @db.Text
  expiresAt    DateTime
  scopes       String[]  // Granted scopes for audit
  connectedAt  DateTime  @default(now())
  lastSyncAt   DateTime?
  updatedAt    DateTime  @updatedAt
}

// Daily Health Context - Aggregated health data per day
model HealthContext {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date          DateTime @db.Date
  
  // Sleep data
  sleepMinutes  Int?     // Total sleep duration in minutes
  sleepQuality  String?  // 'poor', 'fair', 'good', 'excellent' (derived from sleep stages)
  
  // Activity data
  steps         Int?
  activeMinutes Int?     // Minutes of moderate/vigorous activity
  caloriesBurned Int?
  
  // Heart rate (optional)
  avgHeartRate  Int?
  restingHeartRate Int?
  
  // Metadata
  syncedAt      DateTime @default(now())
  source        String   @default("GOOGLE_FIT")
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@unique([userId, date])
  @@index([userId, date])
}

// Health Insights - AI-generated correlations
model HealthInsight {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String   // 'sleep_mood', 'activity_mood', 'pattern', 'weekly_summary'
  title       String
  description String   @db.Text
  data        Json?    // Additional structured data (charts, stats)
  period      String   // 'day', 'week', 'month'
  generatedAt DateTime @default(now())
  
  @@index([userId, type])
}
