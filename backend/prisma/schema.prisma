// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
  SUPERADMIN
}

enum Category {
  PERSONAL
  PROFESSIONAL
}

enum TagSource {
  USER
  AI
  NLP
  IMPORT
  SYSTEM
}

enum AnalysisSource {
  DETERMINISTIC
  NLP
  AI
  IMPORT
}

enum EmbeddingJobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum VoiceTranscriptionJobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELED
}

enum AccountDeletionRequestStatus {
  PENDING
  FULFILLED
  DISMISSED
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  password      String?  // Optional for SSO users
  name          String?
  avatarUrl     String?
  role          Role     @default(USER)
  isBanned      Boolean  @default(false)
  googleId      String?  @unique
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  // Password Reset
  resetToken       String?
  resetTokenExpiry DateTime?

  // Refresh tokens for this user
  refreshTokens RefreshToken[]
  
  // Profile
  profile       UserProfile?
  
  // Journal entries
  entries       Entry[]

  // Tag/analysis relations
  entryTags     EntryTag[]
  entryAnalyses EntryAnalysis[]
  entryEmbeddings EntryEmbedding[]
  entryEmbeddingChunks EntryEmbeddingChunk[]
  entryEmbeddingFacets EntryEmbeddingFacet[]
  embeddingJobs EmbeddingJob[]
  voiceTranscriptionJobs VoiceTranscriptionJob[]
  voiceLexiconItems VoiceLexiconItem[]
  personalizationEvents PersonalizationEvent[]
  accountDeletionRequests AccountDeletionRequest[]
  
  // Chapters
  chapters      Chapter[]
  
  // Social Connections
  socialConnections SocialConnection[]

  // Dashboard Insights
  dashboardInsights       DashboardInsight[]
  insightSurfaceFeedback  InsightSurfaceFeedback[]

  // Device Context & Integrations
  deviceSignals       DeviceSignal[]
  spotifyConnection   SpotifyConnection?
  
  // Push Notifications
  deviceTokens        DeviceToken[]

  // Memory Sharing
  sentBundles         SharedMemoryBundle[]   @relation("sentBundles")
  receivedBundles     SharedMemoryRecipient[] @relation("receivedBundles")
  memoryShareAccessSent      MemoryShareAccess[] @relation("memoryShareAccessSender")
  memoryShareAccessReceived  MemoryShareAccess[] @relation("memoryShareAccessRecipient")
  inAppNotifications  InAppNotification[]
  reminders           Reminder[]

  // Friendships & Blocks
  sentFriendRequests     Friendship[]  @relation("friendshipRequester")
  receivedFriendRequests Friendship[]  @relation("friendshipAddressee")
  blockedUsers           UserBlock[]   @relation("blocker")
  blockedByUsers         UserBlock[]   @relation("blocked")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Entry {
  id          String   @id @default(cuid())
  title       String?
  content     String   @db.Text
  contentHtml String?  @db.Text
  coverImage  String?
  mood        String?
  tags        String[]
  analysis    Json?
  contentVector Unsupported("tsvector")? @map("content_vector")
  category    Category @default(PERSONAL)
  lifeArea    String?  @db.VarChar(64)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  chapterId   String?
  chapter     Chapter? @relation(fields: [chapterId], references: [id], onDelete: SetNull)
  shareLinks  ShareLink[]
  sharedMemoryItems SharedMemoryItem[]
  entryTags   EntryTag[]
  analysisRecord EntryAnalysis?
  entryEmbeddings EntryEmbedding[]
  entryEmbeddingChunks EntryEmbeddingChunk[]
  entryEmbeddingFacets EntryEmbeddingFacet[]
  embeddingJobs EmbeddingJob[]
  voiceTranscriptionJobs VoiceTranscriptionJob[]
  
  // Phase 2: Insights & Sharing
  lessons     String[]
  skills      String[]
  reflection  String?  @db.Text
  isShared    Boolean  @default(false)
  sharedToken String?  @unique
  
  // Phase 3: Social & Extensions
  source      EntrySource @default(NOTIVE)
  externalId  String?
  sourceLink  String?

  // Device context: location captured at entry time
  locationLat  Float?
  locationLng  Float?
  locationName String?  @db.VarChar(200)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  @@index([userId, deletedAt, createdAt])
  @@index([userId, source, externalId])
  @@index([userId, chapterId, createdAt])
  @@index([userId, mood, createdAt])
  @@index([userId, lifeArea, createdAt])
}

model Tag {
  id         String     @id @default(cuid())
  name       String
  normalized String     @unique
  entryTags  EntryTag[]
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@index([normalized])
}

model EntryTag {
  id         String    @id @default(cuid())
  entryId    String
  tagId      String
  userId     String
  source     TagSource @default(USER)
  confidence Float     @default(1.0)
  createdAt  DateTime  @default(now())

  entry Entry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  tag   Tag   @relation(fields: [tagId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([entryId, tagId])
  @@index([userId, createdAt])
  @@index([tagId])
}

model EntryAnalysis {
  id             String         @id @default(cuid())
  entryId        String         @unique
  userId         String
  source         AnalysisSource @default(NLP)
  contentHash    String?
  summary        String?        @db.Text
  sentimentScore Float?
  sentimentLabel String?
  emotions       Json?
  entities       Json?
  topics         String[]
  keywords       String[]
  suggestedMood  String?
  wordCount      Int?
  readingTime    Int?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  entry Entry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, updatedAt])
}

model EntryEmbedding {
  id         String   @id @default(cuid())
  entryId    String
  userId     String
  model      String   @default("text-embedding-3-small")
  dimensions Int
  contentHash String
  embedding  Unsupported("vector")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  entry Entry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([entryId, model, dimensions])
  @@index([userId, updatedAt])
  @@index([userId, model, dimensions])
}

model EntryEmbeddingChunk {
  id          String   @id @default(cuid())
  entryId     String
  userId      String
  model       String   @default("text-embedding-3-small")
  dimensions  Int
  contentHash String
  chunkIndex  Int
  chunkCount  Int
  chunkText   String   @db.Text
  embedding   Unsupported("vector")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  entry Entry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([entryId, chunkIndex, model, dimensions])
  @@index([entryId, model, dimensions])
  @@index([userId, model, dimensions])
  @@index([userId, updatedAt])
}

model EntryEmbeddingFacet {
  id          String   @id @default(cuid())
  entryId      String
  userId       String
  model        String   @default("text-embedding-3-small")
  dimensions   Int
  contentHash  String
  facetType    String   @db.VarChar(64)
  facetKey     String   @db.VarChar(128)
  facetText    String   @db.Text
  embedding    Unsupported("vector")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  entry Entry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([entryId, facetType, facetKey, model, dimensions])
  @@index([entryId, model, dimensions])
  @@index([userId, model, dimensions])
  @@index([userId, facetType, model, dimensions])
  @@index([userId, updatedAt])
}

model EmbeddingJob {
  id           String             @id @default(cuid())
  entryId       String
  userId        String
  model         String             @default("text-embedding-3-small")
  dimensions    Int
  payload       Json
  status        EmbeddingJobStatus @default(PENDING)
  attemptCount  Int                @default(0)
  maxAttempts   Int                @default(4)
  runAfter      DateTime           @default(now())
  lockedAt      DateTime?
  lockedBy      String?            @db.VarChar(128)
  lastError     String?            @db.Text
  completedAt   DateTime?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  entry Entry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([entryId, model, dimensions])
  @@index([status, runAfter, createdAt])
  @@index([userId, status, runAfter])
  @@index([entryId, status])
}

model VoiceTranscriptionJob {
  id                 String                     @id @default(cuid())
  entryId            String?
  userId             String
  fileName           String?                    @db.VarChar(255)
  mimeType           String                     @db.VarChar(80)
  languageMode       String                     @db.VarChar(32)
  candidateLanguages String[]                  @default([])
  recordingDurationMs Int?
  hintText           String?                    @db.Text
  entryContext       String?                    @db.Text
  payload            Json
  transcript         Json?
  captureMeta        Json?
  status             VoiceTranscriptionJobStatus @default(PENDING)
  provider           String?                    @db.VarChar(64)
  model              String?                    @db.VarChar(128)
  detectedLanguage   String?                    @db.VarChar(32)
  attemptCount       Int                        @default(0)
  maxAttempts        Int                        @default(4)
  runAfter           DateTime                   @default(now())
  startedAt          DateTime?
  lockedAt           DateTime?
  lockedBy           String?                    @db.VarChar(128)
  lastError          String?                    @db.Text
  completedAt        DateTime?
  canceledAt         DateTime?
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt

  entry Entry? @relation(fields: [entryId], references: [id], onDelete: SetNull)
  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status, runAfter, createdAt])
  @@index([userId, status, createdAt])
  @@index([entryId, createdAt])
}

model VoiceLexiconItem {
  id         String   @id @default(cuid())
  userId     String
  canonical  String   @db.VarChar(120)
  normalized String   @db.VarChar(120)
  aliases    String[] @default([])
  locale     String?  @db.VarChar(32)
  itemType   String?  @db.VarChar(40)
  boost      Float    @default(0.6)
  usageCount Int      @default(0)
  lastUsedAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, normalized])
  @@index([userId, locale, usageCount])
  @@index([userId, updatedAt])
}

enum EntrySource {
  NOTIVE
  FACEBOOK
  INSTAGRAM
}

model UserProfile {
  id          String    @id @default(cuid())
  userId      String    @unique
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio         String?   @db.Text
  location    String?
  occupation  String?
  website     String?
  birthDate   DateTime?
  lifeGoals   String[]
  primaryGoal String?
  focusArea   String?
  experienceLevel String?
  writingPreference String?
  starterPrompt String? @db.Text
  outputGoals String[] @default([])
  importPreference String?
  personalizationSignals Json?
  onboardingCompletedAt DateTime?
  personalizationEvents PersonalizationEvent[]
  updatedAt   DateTime  @updatedAt
}

model PersonalizationEvent {
  id         String   @id @default(cuid())
  userId     String
  profileId  String?
  eventType  String
  questionId String?
  field      String?
  value      String?  @db.Text
  pathname   String?
  metadata   Json?
  occurredAt DateTime
  fingerprint String  @db.VarChar(64)
  createdAt  DateTime @default(now())

  user    User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  profile UserProfile? @relation(fields: [profileId], references: [id], onDelete: SetNull)

  @@unique([userId, fingerprint])
  @@index([userId, occurredAt])
  @@index([userId, eventType, occurredAt])
}

model AccountDeletionRequest {
  id              String                       @id @default(cuid())
  email           String
  normalizedEmail String                       @db.VarChar(320)
  reason          String?                      @db.Text
  status          AccountDeletionRequestStatus @default(PENDING)
  requestedVia    String                       @default("WEB")
  matchedUserId   String?
  processedAt     DateTime?
  createdAt       DateTime                     @default(now())
  updatedAt       DateTime                     @updatedAt

  matchedUser User? @relation(fields: [matchedUserId], references: [id], onDelete: SetNull)

  @@index([normalizedEmail, createdAt])
  @@index([status, createdAt])
  @@index([matchedUserId, createdAt])
}

model Chapter {
  id          String   @id @default(cuid())
  name        String
  description String?
  color       String   @default("#6366f1") // Primary purple
  icon        String?  @default("📖")
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  entries     Entry[]
  shareLinks  ShareLink[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ShareLink {
  id        String    @id @default(cuid())
  token     String    @unique @default(cuid())
  entryId   String?
  entry     Entry?    @relation(fields: [entryId], references: [id], onDelete: Cascade)
  chapterId String?
  chapter   Chapter?  @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  expiresAt DateTime?
  createdAt DateTime  @default(now())
}

model SocialConnection {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider     String   // 'INSTAGRAM', 'FACEBOOK'
  providerId   String?  // Social ID
  accessToken  String   @db.Text
  refreshToken String?  @db.Text
  expiresAt    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  @@unique([userId, provider])
}

// Dashboard Insights — LLM-generated personal insights for the dashboard
model DashboardInsight {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category      String   // contradiction, hidden_pattern, growth_signal, blind_spot, evolution
  title         String
  body          String   @db.Text
  evidence      String?  @db.Text
  entryIds      String[] // referenced entry IDs
  qualityScore  Float    @default(0)
  userReaction  String?  // legacy single reaction or serialized reaction history
  llmModel      String?  // model used for generation
  generatedAt   DateTime @default(now())
  expiresAt     DateTime

  @@index([userId, category, generatedAt])
  @@index([userId, expiresAt])
}

model InsightSurfaceFeedback {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  surfaceType String   // correlation | contradiction | trigger | reflection
  entityKey   String   // topic / entryId / entity / reflection signature
  reaction    String   // helpful | not_helpful
  createdAt   DateTime @default(now())

  @@unique([userId, surfaceType, entityKey])
  @@index([userId, surfaceType, createdAt])
}

// ── Device Context Signals ──────────────────────────────────
// Unified table for all device-level daily signals:
// location, calendar, spotify, screen_time, app_usage, notification_pressure

model DeviceSignal {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date        DateTime @db.Date
  signalType  String   @db.VarChar(40)  // location_summary, calendar, spotify, screen_time, app_session, notification, wellness_checkin
  data        Json                       // flexible payload per signal type
  source      String   @default("AUTO") @db.VarChar(20) // AUTO, SELF_REPORT, API
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, date, signalType])
  @@index([userId, date])
  @@index([userId, signalType, date])
}

// Spotify OAuth Connection
model SpotifyConnection {
  id           String    @id @default(cuid())
  userId       String    @unique
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken  String    @db.Text
  refreshToken String    @db.Text
  expiresAt    DateTime
  scopes       String[]
  displayName  String?
  connectedAt  DateTime  @default(now())
  lastSyncAt   DateTime?
  updatedAt    DateTime  @updatedAt
}

// Device Tokens for Push Notifications
model DeviceToken {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token         String   @db.Text
  platform      String   @db.VarChar(32)  // 'android', 'ios', 'web'
  deviceId      String?  @db.VarChar(255) // Hardware device identifier
  deviceName    String?  @db.VarChar(255) // User-friendly device name
  appVersion    String?  @db.VarChar(32)  // App version when token was registered
  osVersion     String?  @db.VarChar(32)  // OS version
  isActive      Boolean  @default(true)
  lastUsedAt    DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([userId, token])
  @@index([userId, platform, isActive])
  @@index([userId, lastUsedAt])
}

// ── Memory Sharing ──────────────────────────────────────

enum SharedBundleStatus {
  ACTIVE
  REVOKED
}

enum MemoryShareAccessStatus {
  PENDING
  ACCEPTED
  DECLINED
}

model SharedMemoryBundle {
  id        String              @id @default(cuid())
  senderId  String
  sender    User                @relation("sentBundles", fields: [senderId], references: [id], onDelete: Cascade)
  message   String?             @db.Text
  status    SharedBundleStatus  @default(ACTIVE)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  items      SharedMemoryItem[]
  recipients SharedMemoryRecipient[]

  @@index([senderId, createdAt])
}

model SharedMemoryItem {
  id        String   @id @default(cuid())
  bundleId  String
  bundle    SharedMemoryBundle @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  entryId   String
  entry     Entry    @relation(fields: [entryId], references: [id], onDelete: Cascade)

  // Snapshot: frozen copy of the entry at share-time
  snapshotTitle     String?
  snapshotContent   String   @db.Text
  snapshotMood      String?
  snapshotTags      String[]
  snapshotCoverImage String?
  snapshotCreatedAt DateTime

  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  @@unique([bundleId, entryId])
  @@index([bundleId, sortOrder])
  @@index([entryId])
}

model SharedMemoryRecipient {
  id          String    @id @default(cuid())
  bundleId    String
  bundle      SharedMemoryBundle @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  recipientId String
  recipient   User      @relation("receivedBundles", fields: [recipientId], references: [id], onDelete: Cascade)

  status      MemoryShareAccessStatus @default(ACCEPTED)
  readAt      DateTime?
  reaction    String?   @db.VarChar(32)
  createdAt   DateTime  @default(now())

  @@unique([bundleId, recipientId])
  @@index([recipientId, status, createdAt])
}

model MemoryShareAccess {
  id          String                  @id @default(cuid())
  senderId    String
  sender      User                    @relation("memoryShareAccessSender", fields: [senderId], references: [id], onDelete: Cascade)
  recipientId String
  recipient   User                    @relation("memoryShareAccessRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  status      MemoryShareAccessStatus @default(PENDING)
  decidedAt   DateTime?
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt

  @@unique([senderId, recipientId])
  @@index([recipientId, status, updatedAt])
  @@index([senderId, status, updatedAt])
}

// ── In-App Notifications ────────────────────────────────

model InAppNotification {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String    @db.VarChar(64)
  title     String
  body      String?   @db.Text
  data      Json?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, readAt, createdAt])
  @@index([userId, type, createdAt])
}

// ── Journal Reminders ─────────────────────────────────────

model Reminder {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  time      String   @db.VarChar(5) // "HH:MM" 24-hour local time
  days      Int[]    // 0=Sun 1=Mon ... 6=Sat; empty = every day
  timezone  String   @default("UTC") @db.VarChar(64)
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, enabled])
}

// ── Friendships ───────────────────────────────────────────
// Bidirectional: once ACCEPTED both users can share with each other.
// requesterId always < addresseeId is NOT enforced — we store the
// direction so we know who initiated.

enum FriendshipStatus {
  PENDING
  ACCEPTED
  DECLINED
}

model Friendship {
  id           String           @id @default(cuid())
  requesterId  String
  requester    User             @relation("friendshipRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  addresseeId  String
  addressee    User             @relation("friendshipAddressee", fields: [addresseeId], references: [id], onDelete: Cascade)
  status       FriendshipStatus @default(PENDING)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@unique([requesterId, addresseeId])
  @@index([addresseeId, status])
  @@index([requesterId, status])
}

// ── User Blocks ───────────────────────────────────────────
// One-directional: blocker stops receiving anything from blocked user.
// Also hides blocker from blocked user's search results.

model UserBlock {
  id        String   @id @default(cuid())
  blockerId String
  blocker   User     @relation("blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blockedId String
  blocked   User     @relation("blocked", fields: [blockedId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([blockerId, blockedId])
  @@index([blockedId])
}
