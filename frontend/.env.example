# Frontend Environment Variables

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
# Optional: override only the native Android/iOS wrapper without affecting web builds
NEXT_PUBLIC_NATIVE_API_URL=
NEXT_PUBLIC_APP_URL=https://notive.abbasaisolutions.com

# Google OAuth Configuration
# Get your web client ID from: https://console.cloud.google.com/apis/credentials
# The backend must also allow this same active web client ID in GOOGLE_CLIENT_ID or GOOGLE_CLIENT_IDS.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com
# Optional: explicit alias for the same web client ID, used by native Google sign-in too
NEXT_PUBLIC_GOOGLE_WEB_CLIENT_ID=
# Optional: only needed if you later ship iOS native Google sign-in
NEXT_PUBLIC_GOOGLE_IOS_CLIENT_ID=

# Optional: surfaced on privacy/account deletion pages if you want a direct contact email
NEXT_PUBLIC_SUPPORT_EMAIL=

# Voice capture rollout
NEXT_PUBLIC_VOICE_BACKEND_TRANSCRIPTION_ENABLED=true
NEXT_PUBLIC_VOICE_ALLOW_BROWSER_FALLBACK=true

# Optional: Analytics
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Optional: Error Tracking (Sentry, etc.)
# NEXT_PUBLIC_SENTRY_DSN=your_sentry_dsn_here
