{
  "name": "notive-frontend",
  "version": "0.1.0",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "node scripts/serve-export.js",
    "android:version": "node scripts/bump-android-version.mjs",
    "android:version:ci": "node scripts/resolve-android-ci-version.mjs",
    "android:version:patch": "node scripts/bump-android-version.mjs patch",
    "android:version:minor": "node scripts/bump-android-version.mjs minor",
    "android:version:major": "node scripts/bump-android-version.mjs major",
    "android:ready": "node scripts/android-readiness.mjs",
    "android:ready:launch": "node scripts/android-readiness.mjs --launch",
    "android:prepare": "node scripts/prepare-android.mjs clean && npm run build && node scripts/prepare-android.mjs verify-export && npx cap sync android && node scripts/prepare-android.mjs verify-android",
    "android:build:debug": "npm run android:prepare && powershell -ExecutionPolicy Bypass -File .\\scripts\\build-android-debug.ps1",
    "android:build:release": "npm run android:ready && npm run android:prepare && powershell -ExecutionPolicy Bypass -File .\\scripts\\build-android-release.ps1",
    "android:open": "npx cap open android",
    "lint": "tsc --noEmit -p tsconfig.typecheck.json",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "smoke:test": "node scripts/production-smoke.mjs",
    "home-action:review": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/home-action-review.mts",
    "ui:audit": "node scripts/ui-audit.js",
    "ui:audit:strict": "set CI_UI_STRICT=1&& node scripts/ui-audit.js",
    "link:audit": "node scripts/link-audit.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@aparajita/capacitor-secure-storage": "^7.1.6",
    "@capacitor/app": "^7.0.1",
    "@capacitor/core": "^7.4.4",
    "@capacitor/geolocation": "^7.0.1",
    "@capacitor/keyboard": "^7.0.6",
    "@capacitor/preferences": "^7.0.1",
    "@capacitor/push-notifications": "^7.0.1",
    "@capacitor/status-bar": "^7.0.6",
    "@capgo/capacitor-social-login": "^7.20.0",
    "@react-oauth/google": "^0.12.2",
    "@sentry/react": "^10.47.0",
    "@tiptap/extension-placeholder": "^3.12.1",
    "@tiptap/extension-underline": "^3.12.1",
    "@tiptap/react": "^3.12.1",
    "@tiptap/starter-kit": "^3.12.1",
    "clsx": "^2.1.0",
    "framer-motion": "^11.18.2",
    "next": "14.2.35",
    "react": "^18",
    "react-dom": "^18",
    "react-easy-crop": "^5.5.7",
    "react-icons": "^5.5.0",
    "tailwind-merge": "^2.2.1"
  },
  "devDependencies": {
    "@capacitor/android": "^7.4.4",
    "@capacitor/cli": "^7.4.4",
    "@capacitor/ios": "^7.4.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.0.1",
    "happy-dom": "^20.8.9",
    "jsdom": "^29.0.1",
    "postcss": "^8",
    "tailwindcss": "^3.3.0",
    "typescript": "^5",
    "vitest": "^4.1.2"
  }
}
